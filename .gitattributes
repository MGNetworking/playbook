# Normalisation — LF dans le dépôt, conversion automatique au checkout
* text=auto eol=lf

# ─── Scripts ─────────────────────────────────────────────────────────────────
*.sh   text eol=lf
*.bash text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# ─── Python ──────────────────────────────────────────────────────────────────
*.py   text eol=lf
*.pyi  text eol=lf
*.toml text eol=lf
*.cfg  text eol=lf

# ─── Documentation ───────────────────────────────────────────────────────────
*.md   text eol=lf
*.txt  text eol=lf
*.rst  text eol=lf

# ─── Config / CI ─────────────────────────────────────────────────────────────
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.json text eol=lf
.env*  text eol=lf

# ─── Binaires ────────────────────────────────────────────────────────────────
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.webp binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
