# Credentials Jira — copier ce fichier en .env et remplir les valeurs
# Le fichier .env ne doit PAS être commité (ajouter .env au .gitignore)

# URL de ton instance Jira Cloud
JIRA_URL=https://xxx.atlassian.net

# Email du compte Jira
JIRA_EMAIL=xxx@xxx.com

# Token API Jira (Account Settings → Security → API tokens → Create)
# Ce n'est PAS ton mot de passe
JIRA_TOKEN=xxx

# Clé du projet Jira (ex: NUT, CDC, PROJ...)
JIRA_PROJECT_KEY=XX
